      </column>
      <column caption='Lowest County Rank' datatype='integer' name='[Calculation_1141846992125953]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK_DENSE(AVG([Composite_Risk_Score]), &apos;asc&apos;)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
