      <column caption='Avg Sales Per Location' datatype='integer' name='[Avg_Sales_Per_Location]' role='measure' type='quantitative' />
      <column caption='County Rank' datatype='integer' name='[Calculation_1141846991867904]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK_DENSE(AVG([Composite_Risk_Score]), &apos;desc&apos;)'>
          <table-calc ordering-type='Rows' />
